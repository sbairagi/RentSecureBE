[MASTER]
init-hook='import sys; sys.path.append(".")'
load-plugins=pylint_django
django-settings-module=rentsecure_be.settings
ignore=migrations,venv,.venv,tests
jobs=1
persistent=yes

[MESSAGES CONTROL]
disable=
    missing-docstring,
    invalid-name,
    too-few-public-methods,
    too-many-arguments,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-nested-blocks,
    too-many-return-statements,
    too-many-instance-attributes,
    too-many-public-methods,
    duplicate-code,
    fixme,
    no-else-return,
    inconsistent-return-statements

[REPORTS]
output-format=colorized
reports=no
score=yes

[FORMAT]
max-line-length=88
indent-string='    '

[TYPECHECK]
ignore-mixin-members=yes
generated-members=request,objects,objects.filter,objects.get,apply_async,delay,transaction,signals,register

[SIMILARITIES]
min-similarity-lines=4

[BASIC]
good-names=i,j,k,ex,Run,_,pk,id,db,qs
good-names-long=serializer,request,response,kwargs
