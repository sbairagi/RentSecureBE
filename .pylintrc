[MASTER]
init-hook='import os, sys; sys.path.insert(0, os.getcwd())'
load-plugins=pylint_django
django-settings-module=rentsecure_be.settings
ignore=migrations,venv,.venv,tests,original_models.py,refactored_models_combined.py
ignore-patterns=^test_.*\.py$,^.*_tests\.py$,^tests\.py$
jobs=1
persistent=no

[MESSAGES CONTROL]
disable=
    missing-docstring,
    invalid-name,
    too-few-public-methods,
    too-many-arguments,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-nested-blocks,
    too-many-return-statements,
    too-many-instance-attributes,
    too-many-public-methods,
    duplicate-code,
    fixme,
    no-else-return,
    inconsistent-return-statements,
    too-many-ancestors,
    broad-exception-caught,
    import-outside-toplevel,
    unused-argument,
    unused-import,
    logging-fstring-interpolation,
    arguments-renamed,
    cyclic-import

[REPORTS]
output-format=colorized
reports=no
score=yes

[FORMAT]
max-line-length=88
indent-string='    '

[TYPECHECK]
ignore-mixin-members=yes
generated-members=request,objects,objects.filter,objects.get,apply_async,delay,transaction,signals,register,order,policeverification

[SIMILARITIES]
min-similarity-lines=4

[BASIC]
good-names=i,j,k,ex,Run,_,pk,id,db,qs,serializer,request,response,kwargs
