venv/
env/
ENV/
.venv/

# PyCharm or VSCode project files
.idea/
.vscode/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage*
*.cover
*.py,cover

# pytest cache
.pytest_cache/

# mypy type checker
.mypy_cache/

# ruff cache
.ruff_cache/

# pytype static type analyzer
.pytype/

# pyre type checker
.pyre/

# nox
.nox/

# tox
.tox/

# mutmut mutation testing
.mutmut-cache/
mutants/

# Benchmark results
benchmark-results.json

# Profiling output
*.prof

