architecture/generated/

# Generated UML artifacts
docs/uml/generated/
docs/diagrams/generated/

# Generated history artifacts
docs/history/generated/
docs/history/generated-reports/

# Django migrations (optional: you may want to include them if you track migrations)
# migrations/

# Environment variables file (if any)
.env
.env.*
!.env.example

# Node dependencies
node_modules/

# Mac system files
.DS_Store

# Logs
*.log

# celery beat schedule file
celerybeat-schedule

# local settings
local_settings.py
**/config.yaml

