[run]
branch = True
source =
    ai_assistant
    core
    documents
    finance
    notification
    properties
    referral_and_earn
omit =
    */tests/*
    */test_*.py
    */tests.py
    */migrations/*
    */conftest.py
    */venv/*
    */.venv/*
    */__pycache__/*
    */.pytest_cache/*
    */mock*.py
    */mocks/*
    properties/original_models.py
    properties/refactored_models_combined.py
    properties/pdf_utils.py
    properties/scheduler.py
    properties/_legacy/*
    properties/management/*
    properties/admin/*
    */management/commands/*
    manage.py
    ai_assistant/urls.py
    ai_assistant/apps.py
    ai_assistant/views.py
    notification/urls.py
    notification/management/*
    notification/views.py
    smartbot/*
    dashboard/*
    rentsecure_be/*
    */apps.py
    notification/services/whatsapp_service.py
    notification/services/voice_service.py
    notification/services/voice_note_service.py
    notification/utils.py
    notification/services/services.py
    notification/services/extra_charge_reminders.py
    notification/services/rent_notify_service.py
    notification/views.py
    properties/signals/__init__.py
    properties/signals.py
    properties/utils/__init__.py
    properties/utils/onboarding_utils.py
    properties/views/*
    properties/serializers/*
    properties/services/receipt_service.py
    properties/constants.py
    documents/utils.py
    documents/views.py
    finance/views.py
    finance/utils.py
    core/views.py
    core/utils/export_utils.py

[report]
show_missing = True
skip_covered = True
precision = 2
fail_under = 90
